# Copy this file to .env and fill in your values

# OpenRouter API key — powers the owner AI chat (customer booking works without it)
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# Which model the owner assistant uses — any slug from https://openrouter.ai/models
OPENROUTER_MODEL=anthropic/claude-3.7-sonnet

# Password for the owner chat page
OWNER_PASSWORD=change-me

# Port for the web server
PORT=3000

# --- Payments (Stripe) ---
# Leave STRIPE_SECRET_KEY blank to disable payments — bookings then confirm
# instantly with no deposit (the pre-payment behaviour). Use a test key
# (sk_test_...) from https://dashboard.stripe.com/test/apikeys to enable.
STRIPE_SECRET_KEY=
# From `stripe listen` or the webhook settings — needed to verify webhooks.
STRIPE_WEBHOOK_SECRET=
# Deposit taken to hold a booking, in whole pounds.
DEPOSIT_AMOUNT=50
# Public base URL Stripe redirects back to after checkout.
PUBLIC_BASE_URL=http://localhost:3000

# Demo mode: shows a "no real charge will be taken" banner on the booking page
# and, as a safety net, refuses to take real payments if a live Stripe key
# (sk_live_) is set. Use with sk_test_ keys for a shareable sales demo.
DEMO_MODE=
